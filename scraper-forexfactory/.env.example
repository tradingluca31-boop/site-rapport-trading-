# ForexFactory scraper — variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs réelles
# NE JAMAIS commit le .env (déjà dans .gitignore par défaut)

# URL du projet Supabase (identique à celui utilisé pour mt5_calendar)
SUPABASE_URL=https://kzwsokuppgcbkjphecpn.supabase.co

# Clé service_role (ÉCRITURE, bypass RLS)
# Dashboard Supabase > Project Settings > API > service_role (secret)
# ATTENTION : jamais côté navigateur, jamais commit
SUPABASE_SERVICE_ROLE_KEY=__REMPLIR_ICI__
